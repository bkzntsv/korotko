# Telegram Bot Token
# Получить можно у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Azure OpenAI Configuration (required)
# Base URL вашего Azure OpenAI ресурса
# Может быть в формате:
# - https://your-resource.openai.azure.com/openai/v1/ (рекомендуется)
# - https://your-resource.openai.azure.com
# - https://your-resource.cognitiveservices.azure.com (для некоторых ресурсов)
# ВАЖНО: Используйте тот формат, который указан в вашем Azure Portal!
# Пример: https://duos-dev-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1/
# API Key для Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# Поддерживаемые модели через запятую
# ВАЖНО: Указывайте ТОЧНОЕ ИМЯ DEPLOYMENT из Azure Portal, а не имя модели!
# Например, если в Azure Portal deployment называется "gpt-4o-deployment", 
# то укажите: AZURE_SUPPORTED_MODELS=gpt-4o-deployment
# НЕ используйте просто "gpt-4o" - это имя модели, а не deployment!
AZURE_SUPPORTED_MODELS=gpt-4o
# Reasoning модели через запятую (используются для всех типов ссылок)
# Указывайте deployment names, например: o3-mini, o1-mini
# Пример: AZURE_REASONING_MODELS=o3-mini
# Если указано, будет использоваться первая reasoning модель для всех запросов
AZURE_REASONING_MODELS=o3-mini
# Отдельные base URL для моделей (опционально)
# Формат: model1:url1,model2:url2
# Если не указано, используется AZURE_OPENAI_BASE_URL для всех моделей
# Пример: AZURE_MODEL_BASE_URLS=gpt-4o:https://resource1.openai.azure.com,o3-mini:https://resource2.openai.azure.com
# Или: AZURE_MODEL_BASE_URLS=gpt-4o:https://resource1.openai.azure.com/openai/v1/,o3-mini:https://resource2.openai.azure.com/openai/v1/
AZURE_MODEL_BASE_URLS=

# ZenRows API Key
ZENROWS_API_KEY=0ab0323ffa5dda49b8a3f44ca2a0cd5561633a7b

# LinkedIn Cookie (li_at) - Optional, but recommended for full profile data
# Get it from browser after logging into LinkedIn: 
# 1. Open LinkedIn in browser
# 2. Open DevTools (F12) -> Application -> Cookies -> linkedin.com
# 3. Copy value of "li_at" cookie
LINKEDIN_COOKIE=

# User Agent
USER_AGENT=Mozilla/5.0 (compatible; Bot/1.0)
